# Required for backend
# Generate 32 random bytes and base64 encode.
# Example (PowerShell): [Convert]::ToBase64String((1..32 | ForEach-Object {Get-Random -Maximum 256}))
AES_256_KEY=replace_with_base64_32byte_key

# Gemini API key
GEMINI_API_KEY=replace_with_gemini_key

# Groq API key (required for ml_service)
GROQ_API_KEY=replace_with_groq_key

# Optional Docker ML settings
# If set to true, backend bridges audio to ml_service over WebSocket.
USE_LOCAL_ML=true
# Backend -> ML bridge URL inside Docker network
ML_NODE_URL=ws://ml-service:8002/ws/process-audio
# Path in the ml_service container where your GGUF model exists
LLAMA_MODEL_PATH=/models/Qwen3.5-2B-Q4_K_M.gguf
# Optional direct download URL for GGUF if model file is missing at LLAMA_MODEL_PATH
LLAMA_MODEL_URL=
# llama.cpp runtime tuning (good defaults for Apple Silicon + Docker)
LLAMA_CONTEXT_SIZE=1536
LLAMA_THREADS=2
LLAMA_BATCH_THREADS=2
LLAMA_N_PARALLEL=1
LLAMA_SPEC_TYPE=ngram-mod
LLAMA_SPEC_NGRAM_SIZE_N=24
LLAMA_DRAFT_MIN=48
LLAMA_DRAFT_MAX=64
QWEN_N_KEEP=192
VAD_MIN_RMS=0.0055
VAD_START_RATIO=2.2
VAD_CONTINUE_RATIO=1.45
VAD_NOISE_ALPHA=0.97
VAD_HANGOVER_FRAMES=14
VAD_MAX_SILENCE_FRAMES=40
VAD_PRE_ROLL_FRAMES=8
VAD_MAX_ZCR=0.35
VAD_NOISE_GATE_RATIO=1.15
MIN_SPEECH_SAMPLES=10000
MAX_SPEECH_SAMPLES=480000
STT_COALESCE_WINDOW_SEC=0.8
STT_MIN_REQUEST_INTERVAL_SEC=1.1
STT_DUP_SIMILARITY=0.92
STT_DUP_WINDOW_SEC=8.0
